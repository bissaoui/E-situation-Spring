DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=change-me

SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8080

# Use only if you serve BE files from a local filesystem.
# BE_FILES_BASE_PATH=/path/to/be/files

APP_ADMIN_PASSWORD=change-me
APP_USER_PASSWORD=change-me
APP_DG_PASSWORD=change-me
APP_DAF_PASSWORD=change-me
APP_DDZA_PASSWORD=change-me
APP_DDZO_PASSWORD=change-me

RATE_LIMIT_PER_MINUTE=120
# Base64-encoded signing secret used for JWTs. Keep it stable across deploys.
JWT_SECRET=generate-a-long-random-base64-secret
# Base64-encoded 32-byte AES key used for field-level data encryption.
# Keep it stable across deploys or previously encrypted Situation rows will fail to decrypt.
DATA_ENCRYPTION_KEY=generate-a-base64-encoded-32-byte-key
JWT_EXPIRATION_SECONDS=7200

APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

BE_IMPORT_SOURCE=onedrive
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
ONEDRIVE_USER_EMAIL=your-user@example.com
ONEDRIVE_FILE_PATH=
ONEDRIVE_FOLDER_PATH=your/onedrive/folder/path
